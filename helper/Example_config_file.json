{
  "pre_filter": {
    "type": "ButterworthFilter",
    "params": {
      "cutoff": 0.05,
      "order": 2,
      "time_unit": "min"
    }
  },
  "post_filter": {
    "type": "SavitzkyGolayFilter",
    "params": {
      "window_length": 9,
      "polyorder": 2
    }
  },
  "cut_reactive": {
    "enabled": true,
    "mode": "both",
    "upper_temp": 500
  },
  "cut_tail": {
    "enabled": false,
    "threshold": -0.8,
    "buffer": 200
  },
  "temperature_correction": {
    "use": "no",
    "calibration_file": "TemperatureCalibration.json"
  },
  "gas_columns": {
    "Gas1": "CO",
    "Gas2": "CO2",
    "Purge": "Ar",
    "Water": "water_ml"
  }
}
